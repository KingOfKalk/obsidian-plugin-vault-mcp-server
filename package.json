{
  "name": "vault-mcp-server",
  "version": "2.7.1",
  "description": "Exposes your Obsidian vault as a Model Context Protocol server for AI assistants",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/ scripts/",
    "lint:fix": "eslint src/ tests/ scripts/ --fix",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "typecheck": "tsc --noEmit",
    "docs:tools": "tsx scripts/list-tools.ts docs/tools.generated.md",
    "docs:check": "tsx scripts/list-tools.ts /tmp/tools.check.md && diff -u docs/tools.generated.md /tmp/tools.check.md"
  },
  "keywords": [
    "obsidian",
    "mcp",
    "model-context-protocol"
  ],
  "author": "KingOfKalk",
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "builtin-modules": "^5.1.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "prettier": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "moment": "^2.30.1",
    "obsidian": "^1.7.2",
    "selfsigned": "^5.5.0",
    "zod": "^4.4.3"
  }
}
